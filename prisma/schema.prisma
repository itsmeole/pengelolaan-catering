datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  VENDOR
  ADMIN
}

model StudentValidation {
  id        String   @id @default(cuid())
  nis       String   @unique
  name      String
  class     String
}

enum OrderStatus {
  PENDING
  PAID
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH_PAY_LATER
  TRANSFER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  image         String?   @db.LongText
  role          Role      @default(STUDENT)
  
  // Student specific
  nis           String?   @unique
  class         String?
  
  // Vendor specific
  vendorName    String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  orders        Order[]
  menuItems     MenuItem[]
  reviews       Review[]
}

model MenuItem {
  id          String      @id @default(cuid())
  vendorId    String
  vendor      User        @relation(fields: [vendorId], references: [id])
  name        String
  description String      @db.Text
  price       Float
  imageUrl    String?     @db.LongText
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orderItems  OrderItem[]
}

model Order {
  id            String        @id @default(cuid())
  studentId     String
  student       User          @relation(fields: [studentId], references: [id])
  totalAmount   Float
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  proofImage    String?       @db.LongText
  transferDate  DateTime?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items         OrderItem[]
}

model OrderItem {
  id        String    @id @default(cuid())
  orderId   String
  order     Order     @relation(fields: [orderId], references: [id])
  menuId    String
  menu      MenuItem  @relation(fields: [menuId], references: [id])
  
  date      DateTime
  quantity  Int       @default(1)
  note      String?
  
  price     Float     // Snapshot price
  
  review    Review?
}

model Review {
  id          String    @id @default(cuid())
  studentId   String
  student     User      @relation(fields: [studentId], references: [id])
  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  
  rating      Int
  comment     String?
  
  createdAt   DateTime  @default(now())
}

model SystemSetting {
  key   String @id
  value String @db.Text
  
  updatedAt DateTime @updatedAt
}
